# Tesla findus cookies (get from DevTools Network tab, see README_PRICING.md)
TESLA_COOKIES=

# Cloudflare tunnel token for remote access via docker-compose (see README.md)
CLOUDFLARE_TUNNEL_TOKEN=

# Mapbox API token (server-side only — used by /api/route + /api/geocode).
# Create at https://account.mapbox.com/access-tokens. A public pk.* token
# works; restrict it to the production hostname and to just the Directions
# + Geocoding APIs. Both endpoints return 503 when unset.
MAPBOX_TOKEN=
