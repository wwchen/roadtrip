#!/usr/bin/env bash
# Run backend tests before pushing. Skip when no backend code changed in the
# range about to be pushed, and skip entirely under SKIP_PREPUSH=1 for the
# rare "yes I know, just push it" case. Enable with `make install-hooks`.
#
# Pre-push (vs pre-commit) is the right gate for tests: pre-commit runs every
# few minutes during a flow session and slow tests would train people to
# --no-verify, while pre-push only fires when work is leaving the laptop.
set -euo pipefail

if [ "${SKIP_PREPUSH:-}" = "1" ]; then
  echo "pre-push: SKIP_PREPUSH=1 — skipping tests"
  exit 0
fi

# git pipes <local-ref> <local-sha> <remote-ref> <remote-sha> on stdin, one
# line per ref being pushed. Aggregate the changed-file set across all of
# them so a multi-ref push still gates correctly.
zero="0000000000000000000000000000000000000000"
changed=""
while read -r local_ref local_sha remote_ref remote_sha; do
  [ -z "${local_sha:-}" ] && continue
  [ "$local_sha" = "$zero" ] && continue  # branch deletion
  if [ "$remote_sha" = "$zero" ]; then
    # New branch — diff against the merge-base with origin/master so we don't
    # rebuild the world for a long-lived feature branch.
    base=$(git merge-base "$local_sha" origin/master 2>/dev/null || echo "")
    range=${base:+"$base..$local_sha"}
    range=${range:-"$local_sha"}
  else
    range="$remote_sha..$local_sha"
  fi
  changed+=$(git diff --name-only "$range" 2>/dev/null || true)$'\n'
done

if ! echo "$changed" | grep -qE '^backend/'; then
  echo "pre-push: no backend changes — skipping tests"
  exit 0
fi

echo "pre-push: running backend tests…"
cd backend
if ! ./gradlew --quiet test -x generateJooq; then
  echo
  echo "Backend tests failed. Override (use sparingly) with: SKIP_PREPUSH=1 git push"
  exit 1
fi
