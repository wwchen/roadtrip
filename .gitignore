.env
.env.*
!.env.example
samples/
node_modules/
.DS_Store
__pycache__/
*.pyc
.gstack/

# Backend (Kotlin) build artifacts. jOOQ generated classes are regenerated
# at build time via Testcontainers + Flyway, so they don't need to be checked in.
backend/.gradle/
backend/.kotlin/
backend/build/

# Playwright smoke artifacts. Tests live in qa/, deps + browser cache + run
# results all stay local.
qa/test-results/
qa/playwright-report/

.idea/
.obsidian/

# RFC 0007 raw captures. Each fetcher writes envelope-wrapped upstream
# bytes here on every run. Append-only on the poller host, but not
# committed — captures are large (~40MB and growing) and machine-
# specific. Recovery on a fresh checkout: re-run the fetchers, or run
# scripts/_migrate_tesla_cache.py to bootstrap Tesla from the legacy
# data/pricing-cache/ if it's still around.
data/raw/
