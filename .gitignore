# Tesla's bulk get-locations feed is 12 MB and regenerable from the saved
# curl in scripts/fetch_tesla_superchargers.py docs. The downstream
# data/tesla-superchargers.geojson IS checked in.
data/tesla-locations-us.json

# Backend (Kotlin) build artifacts. jOOQ generated classes are regenerated
# at build time via Testcontainers + Flyway, so they don't need to be checked in.
backend/.gradle/
backend/build/

# Playwright smoke artifacts. Tests live in qa/, deps + browser cache + run
# results all stay local.
qa/test-results/
qa/playwright-report/

.idea/
